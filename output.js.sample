  {
    "id": "2",
    "name": "inventory-service",
    "files": {
      "file:///opt/input/source/src/main/java/com/example/inventory/InventoryResource.java": "package com.example.inventory;\n\nimport javax.inject.Inject;\nimport javax.ws.rs.*;\nimport javax.ws.rs.core.MediaType;\nimport javax.ws.rs.core.Response;\n\n@Path(\"/inventory\")\n@Produces(MediaType.APPLICATION_JSON)\n@Consumes(MediaType.APPLICATION_JSON)\npublic class InventoryResource {\n\n    @Inject\n    private InventoryRepository repo;\n\n    @GET\n    public Response list() {\n        return Response.ok(repo.findAll()).build();\n    }\n\n    @PUT\n    @Path(\"/{sku}\")\n    public Response update(@PathParam(\"sku\") String sku, InventoryItem item) {\n        repo.update(sku, item);\n        return Response.ok(item).build();\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/inventory/InventoryItem.java": "package com.example.inventory;\n\nimport javax.persistence.*;\nimport javax.validation.constraints.Min;\nimport javax.validation.constraints.NotNull;\n\n@Entity\n@Table(name = \"inventory\")\npublic class InventoryItem {\n\n    @Id\n    private String sku;\n\n    @NotNull\n    private String name;\n\n    @Min(0)\n    @Column(name = \"quantity\")\n    private int quantity;\n\n    public String getSku() { return sku; }\n    public void setSku(String sku) { this.sku = sku; }\n    public String getName() { return name; }\n    public void setName(String name) { this.name = name; }\n    public int getQuantity() { return quantity; }\n    public void setQuantity(int quantity) { this.quantity = quantity; }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/inventory/InventoryRepository.java": "package com.example.inventory;\n\nimport javax.enterprise.context.ApplicationScoped;\nimport javax.persistence.EntityManager;\nimport javax.persistence.PersistenceContext;\nimport javax.transaction.Transactional;\nimport java.util.List;\n\n@ApplicationScoped\npublic class InventoryRepository {\n\n    @PersistenceContext\n    private EntityManager em;\n\n    public List<InventoryItem> findAll() {\n        return em.createQuery(\"SELECT i FROM InventoryItem i\", InventoryItem.class).getResultList();\n    }\n\n    @Transactional\n    public void update(String sku, InventoryItem item) {\n        item.setSku(sku);\n        em.merge(item);\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/inventory/InventoryApp.java": "package com.example.inventory;\n\nimport javax.ws.rs.ApplicationPath;\nimport javax.ws.rs.core.Application;\n\n@ApplicationPath(\"/api\")\npublic class InventoryApp extends Application {\n}\n"
    },
