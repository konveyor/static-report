window["apps"] = [
  {
    "id": "1",
    "name": "customer-service",
    "files": {
      "file:///opt/input/source/src/main/java/com/example/customer/CustomerService.java": "package com.example.customer;\n\nimport javax.ejb.Stateless;\nimport javax.inject.Inject;\nimport javax.persistence.EntityManager;\nimport javax.persistence.PersistenceContext;\nimport javax.ws.rs.*;\nimport javax.ws.rs.core.MediaType;\nimport javax.ws.rs.core.Response;\nimport javax.transaction.Transactional;\n\n@Stateless\n@Path(\"/customers\")\n@Produces(MediaType.APPLICATION_JSON)\n@Consumes(MediaType.APPLICATION_JSON)\npublic class CustomerService {\n\n    @PersistenceContext\n    private EntityManager em;\n\n    @Inject\n    private CustomerValidator validator;\n\n    @GET\n    public Response listAll() {\n        return Response.ok(em.createNamedQuery(\"Customer.findAll\").getResultList()).build();\n    }\n\n    @GET\n    @Path(\"/{id}\")\n    public Response getById(@PathParam(\"id\") Long id) {\n        Customer c = em.find(Customer.class, id);\n        if (c == null) return Response.status(Response.Status.NOT_FOUND).build();\n        return Response.ok(c).build();\n    }\n\n    @POST\n    @Transactional\n    public Response create(Customer customer) {\n        validator.validate(customer);\n        em.persist(customer);\n        return Response.status(Response.Status.CREATED).entity(customer).build();\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/Customer.java": "package com.example.customer;\n\nimport javax.persistence.*;\nimport javax.validation.constraints.NotNull;\nimport javax.validation.constraints.Size;\nimport javax.json.bind.annotation.JsonbProperty;\n\n@Entity\n@Table(name = \"customers\")\n@NamedQuery(name = \"Customer.findAll\", query = \"SELECT c FROM Customer c\")\npublic class Customer {\n\n    @Id\n    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    private Long id;\n\n    @NotNull\n    @Size(min = 1, max = 100)\n    @Column(name = \"name\")\n    private String name;\n\n    @JsonbProperty(\"email_address\")\n    @Column(name = \"email\")\n    private String email;\n\n    public Long getId() { return id; }\n    public void setId(Long id) { this.id = id; }\n    public String getName() { return name; }\n    public void setName(String name) { this.name = name; }\n    public String getEmail() { return email; }\n    public void setEmail(String email) { this.email = email; }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/CustomerValidator.java": "package com.example.customer;\n\nimport javax.enterprise.context.ApplicationScoped;\nimport javax.validation.ValidationException;\n\n@ApplicationScoped\npublic class CustomerValidator {\n    public void validate(Customer customer) {\n        if (customer.getName() == null || customer.getName().isEmpty()) {\n            throw new ValidationException(\"Name is required\");\n        }\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/CustomerEventListener.java": "package com.example.customer;\n\nimport javax.ejb.ActivationConfigProperty;\nimport javax.ejb.MessageDriven;\nimport javax.jms.Message;\nimport javax.jms.MessageListener;\nimport javax.jms.TextMessage;\nimport javax.inject.Inject;\nimport java.util.logging.Logger;\n\n@MessageDriven(activationConfig = {\n    @ActivationConfigProperty(propertyName = \"destinationType\", propertyValue = \"javax.jms.Queue\"),\n    @ActivationConfigProperty(propertyName = \"destination\", propertyValue = \"java:/jms/queue/CustomerEvents\")\n})\npublic class CustomerEventListener implements MessageListener {\n\n    private static final Logger LOG = Logger.getLogger(CustomerEventListener.class.getName());\n\n    @Inject\n    private CustomerService service;\n\n    @Override\n    public void onMessage(Message message) {\n        try {\n            TextMessage txt = (TextMessage) message;\n            LOG.info(\"Received customer event: \" + txt.getText());\n        } catch (Exception e) {\n            LOG.severe(\"Failed to process message: \" + e.getMessage());\n        }\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/AppConfig.java": "package com.example.customer;\n\nimport javax.ws.rs.ApplicationPath;\nimport javax.ws.rs.core.Application;\n\n@ApplicationPath(\"/api\")\npublic class AppConfig extends Application {\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/CustomerNotifier.java": "package com.example.customer;\n\nimport javax.annotation.Resource;\nimport javax.enterprise.context.ApplicationScoped;\nimport javax.inject.Inject;\nimport javax.jms.ConnectionFactory;\nimport javax.jms.JMSContext;\nimport javax.jms.Queue;\n\n@ApplicationScoped\npublic class CustomerNotifier {\n\n    @Inject\n    private JMSContext jmsContext;\n\n    @Resource(lookup = \"java:/jms/queue/CustomerNotifications\")\n    private Queue notificationQueue;\n\n    public void notifyCustomerCreated(Customer customer) {\n        jmsContext.createProducer().send(notificationQueue, \"Customer created: \" + customer.getName());\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/HealthCheck.java": "package com.example.customer;\n\nimport javax.enterprise.context.ApplicationScoped;\nimport javax.inject.Inject;\nimport javax.persistence.EntityManager;\nimport javax.persistence.PersistenceContext;\n\n@ApplicationScoped\npublic class HealthCheck {\n\n    @PersistenceContext\n    private EntityManager em;\n\n    public boolean isHealthy() {\n        try {\n            em.createNativeQuery(\"SELECT 1\").getSingleResult();\n            return true;\n        } catch (Exception e) {\n            return false;\n        }\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/CustomerMapper.java": "package com.example.customer;\n\nimport javax.enterprise.context.ApplicationScoped;\nimport javax.json.bind.Jsonb;\nimport javax.json.bind.JsonbBuilder;\n\n@ApplicationScoped\npublic class CustomerMapper {\n\n    private final Jsonb jsonb = JsonbBuilder.create();\n\n    public String toJson(Customer customer) {\n        return jsonb.toJson(customer);\n    }\n\n    public Customer fromJson(String json) {\n        return jsonb.fromJson(json, Customer.class);\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/AuditInterceptor.java": "package com.example.customer;\n\nimport javax.inject.Inject;\nimport javax.interceptor.AroundInvoke;\nimport javax.interceptor.Interceptor;\nimport javax.interceptor.InvocationContext;\nimport java.util.logging.Logger;\n\n@Interceptor\npublic class AuditInterceptor {\n\n    private static final Logger LOG = Logger.getLogger(AuditInterceptor.class.getName());\n\n    @AroundInvoke\n    public Object audit(InvocationContext ctx) throws Exception {\n        LOG.info(\"Invoking: \" + ctx.getMethod().getName());\n        return ctx.proceed();\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/SecurityFilter.java": "package com.example.customer;\n\nimport javax.servlet.*;\nimport javax.servlet.annotation.WebFilter;\nimport javax.servlet.http.HttpServletRequest;\nimport java.io.IOException;\nimport java.util.logging.Logger;\n\n@WebFilter(\"/*\")\npublic class SecurityFilter implements Filter {\n\n    private static final Logger LOG = Logger.getLogger(SecurityFilter.class.getName());\n\n    @Override\n    public void init(FilterConfig config) throws ServletException {}\n\n    @Override\n    public void doFilter(ServletRequest request, ServletResponse response, FilterChain chain)\n            throws IOException, ServletException {\n        HttpServletRequest req = (HttpServletRequest) request;\n        LOG.info(\"Request: \" + req.getMethod() + \" \" + req.getRequestURI());\n        chain.doFilter(request, response);\n    }\n\n    @Override\n    public void destroy() {}\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/BatchProcessor.java": "package com.example.customer;\n\nimport javax.batch.api.AbstractBatchlet;\nimport javax.batch.runtime.context.JobContext;\nimport javax.inject.Inject;\nimport javax.inject.Named;\nimport java.util.logging.Logger;\n\n@Named\npublic class BatchProcessor extends AbstractBatchlet {\n\n    private static final Logger LOG = Logger.getLogger(BatchProcessor.class.getName());\n\n    @Inject\n    private JobContext jobContext;\n\n    @Override\n    public String process() throws Exception {\n        LOG.info(\"Running batch job: \" + jobContext.getJobName());\n        return \"COMPLETED\";\n    }\n}\n",
      "file:///opt/input/source/src/main/java/com/example/customer/CacheManager.java": "package com.example.customer;\n\nimport javax.enterprise.context.ApplicationScoped;\nimport java.util.Map;\nimport java.util.concurrent.ConcurrentHashMap;\n\n@ApplicationScoped\npublic class CacheManager {\n\n    private final Map<Long, Customer> cache = new ConcurrentHashMap<>();\n\n    public Customer get(Long id) {\n        return cache.get(id);\n    }\n\n    public void put(Long id, Customer customer) {\n        cache.put(id, customer);\n    }\n\n    public void evict(Long id) {\n        cache.remove(id);\n    }\n}\n",
      "file:///opt/input/source/src/main/webapp/WEB-INF/web.xml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<web-app xmlns=\"http://xmlns.jcp.org/xml/ns/javaee\"\n         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n         xsi:schemaLocation=\"http://xmlns.jcp.org/xml/ns/javaee\n         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd\"\n         version=\"4.0\">\n    <display-name>customer-service</display-name>\n</web-app>\n"
    },
    "rulesets": [
      {
        "name": "eap8/eap7",
        "description": "Rules for migrating from JBoss EAP 7 to EAP 8 (Jakarta EE 10)",
        "tags": ["Java EE=EJB,JPA,CDI,JAX-RS,JMS,Servlet", "Runtime=EAP"],
        "violations": {
          "javax-to-jakarta-import-00001": {
